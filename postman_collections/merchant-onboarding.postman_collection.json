          "name": "Save Personal Details (Step 0)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"merchant_1600000000000_abcd\",\n  \"step\": 0,\n  \"personalDetails\": {\n    \"title\": \"president\",\n    \"firstName\": \"Jane\",\n    \"lastName\": \"Doe\",\n    \"socialSecurityNumber\": \"123-45-6789\",\n    \"email\": \"jane.doe@example.com\",\n    \"phone\": \"(555) 123-4567\",\n    \"ownerIntent\": \"yes\",\n    \"password\": \"secretPass1\",\n    \"ConfirmPassword\": \"secretPass1\",\n    \"otpOption\": \"phone\",\n    \"referralCode\": \"REF123\"\n  }\n}"
