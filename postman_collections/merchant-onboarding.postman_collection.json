        {
          "name": "Create Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"string\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/onboarding/session",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api","onboarding","session"]
            }
          },
          "response": []
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "header": [],
